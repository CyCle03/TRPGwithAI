# ===== 서버 설정 =====
# AI 제공자/모델/API 키는 이제 앱 안에서 "사용자별"로 등록합니다 (설정 화면).
# 서버 .env에 AI 키를 둘 필요가 없습니다.

# 세션 토큰·API 키 암호화에 쓰는 시크릿 (선택).
# 미설정 시 서버가 자동 생성해 data/.app_secret 에 저장합니다(재시작/재배포 후에도 유지).
# 여러 서버로 확장하거나 직접 관리하고 싶으면 여기에 긴 랜덤 문자열을 넣으세요.
APP_SECRET=

# 프로덕션에서는 production 으로 (인증 쿠키에 Secure 플래그 적용).
NODE_ENV=production

# 서버 포트
PORT=3000
