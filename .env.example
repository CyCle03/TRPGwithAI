# ===== AI GM 두뇌 선택 =====
# gemini (무료 등급, 카드 불필요) 또는 anthropic (Claude, 유료)
AI_PROVIDER=gemini

# ----- Gemini 사용 시 (기본) -----
# Google AI Studio에서 카드 없이 무료 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 모델 (선택). 기본값: gemini-flash-lite-latest (무료 등급에서 분당 제한만 있고 하루 한도가 넉넉함)
# 참고: gemini-flash-latest(3.x)는 무료 하루 20회 하드캡, gemini-2.x-flash 계열은 신규 키에 404.
GEMINI_MODEL=gemini-flash-lite-latest

# ----- Anthropic(Claude) 사용 시 -----
# AI_PROVIDER=anthropic 로 바꾸고 아래 키를 채우면 됩니다.
ANTHROPIC_API_KEY=
# 모델 (선택). 기본값: claude-sonnet-5 (고품질은 claude-opus-4-8)
ANTHROPIC_MODEL=claude-sonnet-5

# ===== 서버 =====
PORT=3000
SAVE_SLOT=default
