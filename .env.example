# ===== AI GM 두뇌 선택 =====
# gemini (무료 등급, 카드 불필요) 또는 anthropic (Claude, 유료)
AI_PROVIDER=gemini

# ----- Gemini 사용 시 (기본) -----
# Google AI Studio에서 카드 없이 무료 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 모델 (선택). 기본값: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ----- Anthropic(Claude) 사용 시 -----
# AI_PROVIDER=anthropic 로 바꾸고 아래 키를 채우면 됩니다.
ANTHROPIC_API_KEY=
# 모델 (선택). 기본값: claude-sonnet-5 (고품질은 claude-opus-4-8)
ANTHROPIC_MODEL=claude-sonnet-5

# ===== 서버 =====
PORT=3000
SAVE_SLOT=default
